# AWS Lambda Development Environment
# Copy this to .env.dev and fill in your values

# Database (will be created by serverless deploy)
DATABASE_URL=postgresql://pmfadmin:YOUR_DB_PASSWORD@pmf-tool-dev.xxxxx.us-east-1.rds.amazonaws.com:5432/postgres
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD

# OpenAI API
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY

# Email Service (Resend)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (will be set after Amplify deployment)
FRONTEND_URL=https://pmf-tool.amplifyapp.com
CORS_ORIGINS=https://pmf-tool.amplifyapp.com

# Optional: Cost controls
DAILY_SPEND_LIMIT_CENTS=5000

# VPC Configuration (will be output after first deploy)
VPC_SECURITY_GROUP_ID=sg-xxxxxxxxx
VPC_SUBNET_ID_1=subnet-xxxxxxxxx
VPC_SUBNET_ID_2=subnet-xxxxxxxxx