{
  "name": "pmf-tool-api",
  "version": "1.0.0",
  "description": "PMF Tool Backend API for AWS Lambda",
  "main": "dist/lambda.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "deploy": "./deploy.sh",
    "deploy:prod": "./deploy.sh prod",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "logs": "serverless logs -f api",
    "logs:prod": "serverless logs -f api --stage prod",
    "remove": "serverless remove",
    "remove:prod": "serverless remove --stage prod",
    "test": "npx tsx e2e-test.ts"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.14.0",
    "@prisma/client": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "express": "^5.0.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "morgan": "^1.10.0",
    "zod": "^4.0.0",
    "openai": "^4.73.1",
    "resend": "^4.0.1",
    "pdfkit": "^0.15.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pdfkit": "^0.13.5",
    "@types/aws-lambda": "^8.10.145",
    "typescript": "^5.7.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "prisma": "^7.0.0",
    "serverless": "^4.4.7",
    "serverless-offline": "^14.0.0",
    "serverless-dotenv-plugin": "^6.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}