{
  "name": "pmf-tool-api",
  "version": "1.0.0",
  "description": "PMF Tool Backend API",
  "main": "dist/lambda.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "build:lambda": "npx prisma generate && node esbuild.config.mjs",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "deploy": "./deploy.sh",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "logs": "serverless logs -f api",
    "remove": "serverless remove",
    "test": "npx tsx e2e-test.ts"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.14.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.6",
    "openai": "^4.73.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "resend": "^4.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.18.0",
    "esbuild": "^0.27.3",
    "prisma": "^7.4.2",
    "serverless": "^3.40.0",
    "serverless-offline": "^14.0.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
